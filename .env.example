# Database
DATABASE_URL="postgresql://user:password@host:5432/breakwater"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<openssl rand -base64 32>"

# Resend
RESEND_API_KEY=""
# Sandbox-mode default; replace with a verified sender once the Resend domain is set up.
RESEND_FROM_EMAIL="Breakwater <onboarding@resend.dev>"
# Set to "1" to force real Resend delivery during local dev (NODE_ENV=development).
# Unset/0 = console.log fallback (default).
FORCE_RESEND_IN_DEV=""

# Hash salts (server-side only — never exposed to client)
SCAN_IP_SALT="<openssl rand -base64 32>"
SCAN_EMAIL_SALT="<openssl rand -base64 32>"

# Branding
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
