# Database
DATABASE_URL="postgresql://user:password@host:5432/breakwater"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<openssl rand -base64 32>"

# Resend
RESEND_API_KEY=""
# Sandbox-mode default; replace with a verified sender once the Resend domain is set up.
EMAIL_FROM="Breakwater <onboarding@resend.dev>"
# Set to "1" to force real Resend delivery during local dev (NODE_ENV=development).
# Unset/0 = console.log fallback (default).
FORCE_RESEND_IN_DEV=""

# Hash salts (server-side only — never exposed to client)
SCAN_IP_SALT="<openssl rand -base64 32>"
SCAN_EMAIL_SALT="<openssl rand -base64 32>"

# Branding
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Inngest (background job dispatcher)
# Get from inngest.com dashboard or Vercel integration
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_APP_ID=breakwater

# Etherscan API (optional, for GOV-002 detector)
# Get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Ethereum RPC endpoints (Plan 02 Phase A.3)
# Public defaults are baked in (Ankr + Cloudflare) so unset values still work.
# Override per-deploy if you have a private provider (Alchemy, Infura, etc.).
PRIMARY_ETH_RPC_URL=https://rpc.ankr.com/eth
FALLBACK_ETH_RPC_URL=https://cloudflare-eth.com

# Feature flag — disable governance module without redeploying (Plan 02 Phase A.4)
# Default: true (module enabled)
# Set to "false" (case-insensitive) to skip governance scan execution
BREAKWATER_GOVERNANCE_MODULE_ENABLED=true
